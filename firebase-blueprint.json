{
  "entities": {
    "User": {
      "title": "User",
      "description": "Core user authentication and profile metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "onboarded": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role", "onboarded"]
    },
    "PatientProfile": {
      "title": "Patient Profile",
      "description": "Extended information for patient users",
      "type": "object",
      "properties": {
        "bloodGroup": { "type": "string" },
        "gender": { "type": "string" },
        "age": { "type": "number" },
        "address": { "type": "string" }
      },
      "required": ["bloodGroup", "gender", "age", "address"]
    },
    "DoctorProfile": {
      "title": "Doctor Profile",
      "description": "Extended information for doctor users",
      "type": "object",
      "properties": {
        "degree": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["degree", "address"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Main user records"
    },
    "/patients/{userId}": {
      "schema": "PatientProfile",
      "description": "Patient-specific data linked via userId"
    },
    "/doctors/{userId}": {
      "schema": "DoctorProfile",
      "description": "Doctor-specific data linked via userId"
    }
  }
}
